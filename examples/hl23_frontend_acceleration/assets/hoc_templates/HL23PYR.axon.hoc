			slopem_NaTg = 9
			gamma_CaDynamics = 0.0005
		}

		distribute_channels("axon","decay_CaDynamics",0,1.000000,0.000000,0.000000,0.000000,226.0000000000)
		distribute_channels("axon","gbar_SK",0,1.000000,0.000000,0.000000,0.000000,0.0145000000)
		distribute_channels("axon","gbar_Ca_LVA",0,1.000000,0.000000,0.000000,0.000000,0.0439000000)
